NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
# Optional server-side alias for the same browser-restricted Maps key.
GOOGLE_MAPS_BROWSER_KEY=
# Also accepted for deployments that already use a generic Maps key name.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_BROWSER_API_KEY=
GOOGLE_MAPS_API_KEY=

# The single primary account allowed to bootstrap or retain Super Admin access.
SUPER_ADMIN_EMAIL=stevengotsauce@gmail.com

# Local testing only. Ignored in production even when set to true.
NEXT_PUBLIC_FORCE_STORE_OPEN=false
